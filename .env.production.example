# Production environment configuration template.
# Copy to `.env` outside the repo and fill every CHANGE_ME value before launch.
# This template is intentionally explicit about current runtime settings.

# ── Database / Redis ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://amo_user:CHANGE_ME@db-host:5432/amo_crm
REDIS_URL=redis://:CHANGE_ME@redis-host:6379/0

# ── Core app / URLs ──────────────────────────────────────────────────────────
BACKEND_URL=https://your-production-domain.example.com
ADMIN_CORS_ORIGINS=https://your-admin-domain.example.com
ENVIRONMENT=production
LOG_LEVEL=WARNING
LOG_FORMAT=json
DEFAULT_PHONE_COUNTRY=RU
METRICS_ENABLED=true

# ── Security ─────────────────────────────────────────────────────────────────
API_KEY=CHANGE_ME
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_AUTH_SECRET=CHANGE_ME
PROVIDER_SETTINGS_SECRET=CHANGE_ME
ADMIN_TOKEN_TTL_SECONDS=28800

# ── Optional Telegram bot ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_PER_IP_PER_MINUTE=60
RATE_LIMIT_CALLS_PER_MINUTE=10
RATE_LIMIT_STEER_PER_CALL_PER_MINUTE=20
RATE_LIMIT_TRANSFER_PER_CALL=3
RATE_LIMIT_TRANSFER_COOLDOWN_SECONDS=60
RATE_LIMIT_CALLS_PER_PHONE_PER_DAY=5
RATE_LIMIT_MAX_CONCURRENT_CALLS=50
RATE_LIMIT_PHONE_REPEAT_COOLDOWN_SECONDS=300

# ── Quiet hours ──────────────────────────────────────────────────────────────
ENFORCE_QUIET_HOURS=true
CALLING_HOUR_START=9
CALLING_HOUR_END=21
CALLING_TIMEZONE=Europe/Moscow

# ── Telephony provider ───────────────────────────────────────────────────────
TELEPHONY_PROVIDER=mango

# ── Mango Office telephony (required for real Mango route) ──────────────────
MANGO_API_BASE_URL=https://app.mango-office.ru/vpbx
MANGO_API_KEY=CHANGE_ME
MANGO_API_SALT=CHANGE_ME
MANGO_SIP_LOGIN=
MANGO_SIP_PASSWORD=
MANGO_SIP_SERVER=
MANGO_FROM_EXT=CHANGE_ME
MANGO_WEBHOOK_SECRET=
MANGO_WEBHOOK_SHARED_SECRET=CHANGE_ME
MANGO_WEBHOOK_IP_ALLOWLIST=
MANGO_ANSWER_WAIT_TIMEOUT_SECONDS=75
MANGO_BRIDGE_CONFIRM_TIMEOUT_SECONDS=12
MANGO_WHISPER_CONFIRM_TIMEOUT_SECONDS=15

# ── Media gateway / FreeSWITCH (required for real Direct voice) ─────────────
MEDIA_GATEWAY_ENABLED=true
MEDIA_GATEWAY_MODE=esl_rtp
MEDIA_GATEWAY_PROVIDER=freeswitch
FREESWITCH_ESL_HOST=84.247.184.72
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
FREESWITCH_SIP_PROFILE=external
FREESWITCH_SIP_DOMAIN=CHANGE_ME
FREESWITCH_SIP_IP=84.247.184.72
FREESWITCH_RTP_IP=84.247.184.72
FREESWITCH_WS_URL=ws://84.247.184.72:5066
FREESWITCH_WSS_URL=wss://84.247.184.72:7443
FREESWITCH_RTP_PORT_START=16384
FREESWITCH_RTP_PORT_END=32768
FREESWITCH_SESSION_TIMEOUT_SECONDS=120
FREESWITCH_RTP_PAYLOAD_TYPE=96
FREESWITCH_ATTACH_COMMAND_TEMPLATE=uuid_media_reneg {uuid} ={rtp_ip}:{rtp_port}
FREESWITCH_HANGUP_COMMAND_TEMPLATE=uuid_kill {uuid}
FREESWITCH_ESL_EVENTS=CHANNEL_HANGUP_COMPLETE CUSTOM HEARTBEAT
FREESWITCH_ESL_CONNECT_TIMEOUT_SECONDS=5.0
FREESWITCH_ESL_RECONNECT_ENABLED=true
FREESWITCH_ESL_RECONNECT_INITIAL_DELAY_SECONDS=0.5
FREESWITCH_ESL_RECONNECT_MAX_DELAY_SECONDS=5.0
FREESWITCH_ESL_RECONNECT_MAX_ATTEMPTS=0
FREESWITCH_RTP_INBOUND_CODEC=pcm16
FREESWITCH_RTP_OUTBOUND_CODEC=pcm16
FREESWITCH_RTP_SAMPLE_RATE_HZ=16000
FREESWITCH_RTP_FRAME_BYTES=640
FREESWITCH_RTP_INBOUND_TIMEOUT_SECONDS=15
FREESWITCH_RTP_OUTBOUND_BUFFER_MAX_FRAMES=50
FREESWITCH_EVENT_QUEUE_MAX=512

# ── Vapi (only if used as route) ─────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_SERVER_URL=
VAPI_WEBHOOK_SECRET=
VAPI_BASE_URL=https://api.vapi.ai

# ── Transfer settings ────────────────────────────────────────────────────────
TRANSFER_MANAGER_ANSWER_TIMEOUT=30
TRANSFER_BRIEFING_TIMEOUT=15
TRANSFER_BRIDGE_TIMEOUT=10
TRANSFER_MAX_MANAGER_ATTEMPTS=3
TRANSFER_MANAGER_COOLDOWN_SECONDS=300
TRANSFER_MANAGER_RESTORE_ENABLED=true
TRANSFER_MANAGER_RESTORE_INTERVAL_SECONDS=30

# ── Direct runtime / Gemini ──────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL_ID=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_TTS_MODEL_ID=
GEMINI_API_VERSION=v1beta
GEMINI_TTS_API_VERSION=
GEMINI_SYSTEM_PROMPT=Ты — AI ассистент по продажам. Отвечай по-русски. Будь кратким и вежливым.
GEMINI_SETUP_TIMEOUT=5.0
DIRECT_MAX_SESSIONS=10
DIRECT_VOICE_STRATEGY=tts_primary
DIRECT_VOICE_ALLOW_TTS_FALLBACK=true
GEMINI_AUDIO_OUTPUT_ENABLED=false
GEMINI_AUDIO_INPUT_ENABLED=true
DIRECT_INITIAL_GREETING_ENABLED=true
DIRECT_INITIAL_GREETING_TEXT=Здравствуйте! Это AI-ассистент. Чем могу помочь?
DIRECT_MODEL_RESPONSE_TIMEOUT_SECONDS=8.0
SUMMARY_LLM_PROVIDER=

# ── ElevenLabs TTS (required for tts_primary) ────────────────────────────────
ELEVENLABS_API_KEY=CHANGE_ME
ELEVENLABS_VOICE_ID=CHANGE_ME
ELEVENLABS_ENABLED=true
